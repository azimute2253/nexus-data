# Supabase — shared with azimute-blog (same project)
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Migration script — auth.users UUID for the portfolio owner
NEXUS_USER_ID=your-auth-user-uuid

# Price refresh cooldown (hours) — auto-refresh triggers if last refresh > this (Story 3.6)
PRICE_REFRESH_COOLDOWN_HOURS=4
